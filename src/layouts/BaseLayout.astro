---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Francisca Gil — Abogada | Derecho Laboral y Ambiental",
  description = "Francisca Gil, Abogada. Derecho Laboral y Derecho Ambiental. Región de la Araucanía y todo Chile.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Ir al contenido</a>
    <slot />
  </body>
</html>
